# =========================================================================
# Emerald Store - Environment Variables Configuration Template
# =========================================================================

# 1. DATABASE CONFIGURATION (Prisma ORM)
# Replace this with your Neon PostgreSQL or local PostgreSQL connection string.
# Example: postgresql://username:password@ep-cool-flower-12345.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"

# 2. NEXTAUTH CONFIGURATION
# NEXTAUTH_URL: The base URL of your application (required for production redirects)
# NEXTAUTH_SECRET: A secure, random string used to hash and encrypt NextAuth session tokens
# You can generate a secret by running: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_jwt_token_secret_here"

# 3. RAZORPAY PAYMENT GATEWAY KEYS
# NEXT_PUBLIC_RAZORPAY_KEY_ID: Exposed to client-side react code to trigger checkout popups.
# RAZORPAY_KEY_SECRET: Private secret key used to verify payment orders in server APIs.
# Get these from Razorpay Dashboard > Settings > API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_client_key_here"
RAZORPAY_KEY_SECRET="your_private_razorpay_secret_here"

# 4. CLOUDINARY MEDIA UPLOAD CONFIGURATION
# CLOUDINARY_URL: Full connection string from Cloudinary API Dashboard
# CLOUDINARY_CLOUD_NAME: Your Cloudinary cloud identifier (e.g. dmw7xyz)
# CLOUDINARY_UPLOAD_PRESET: An unsigned upload preset name (default: ml_default)
# Get these from Cloudinary Dashboard > Settings > Upload > Upload presets
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_UPLOAD_PRESET="ml_default"
